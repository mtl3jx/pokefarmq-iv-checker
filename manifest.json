{
  "manifest_version": 3,
  "name": "PokéFarm Q IV Checker",
  "version": "1.0.1",
  "description": "View Pokémon IV stats directly in PokéFarm Q field tooltips with perfect IV highlights.",
  "permissions": [],
  "host_permissions": [
    "https://pokefarm.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.pokefarm.com/fields*",
        "*://*.pokefarm.com/party*",
        "*://*.pokefarm.com/user*",
        "*://*.pokefarm.com/trade*",
        "*://*.pokefarm.com/shelter*"
      ],
      "js": [
        "config/env.js",
        "utils/array-utils.js",
        "utils/browser-storage.js",
        "utils/html-generator.js",
        "networking/fetch-url.js",
        "networking/pfq-service.js",
        "data/repository.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "type": "module"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pfq-iv-checker@luansing.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}