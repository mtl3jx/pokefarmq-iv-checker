{
  "manifest_version": 3,
  "name": "PokéFarm Q IV Checker",
  "version": "1.0",
  "description": "View Pokémon IV stats directly in PokéFarm Q field tooltips with perfect IV highlights.",
  "permissions": [],
  "host_permissions": [
    "https://pokefarm.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://pokefarm.com/fields*",
        "https://pokefarm.com/party*",
        "https://pokefarm.com/user*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pfq-iv-checker@luansing.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}