{
  "manifest_version": 3,
  "name": "PokéFarm Q IV Checker",
  "version": "1.1",
  "description": "View Pokémon IV stats directly in PokéFarm Q field tooltips with perfect IV highlights.",
  "host_permissions": [
    "https://pokefarm.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://pokefarm.com/fields*",
        "https://pokefarm.com/party*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}