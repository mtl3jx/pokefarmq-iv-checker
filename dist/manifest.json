{
  "manifest_version": 3,
  "name": "PokéFarm Q IV Checker",
  "version": "1.0.3",
  "description": "View Pokémon IV stats directly in PokéFarm Q field tooltips with perfect IV highlights.",
  "permissions": [],
  "host_permissions": [
    "https://pokefarm.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.pokefarm.com/fields*",
        "*://*.pokefarm.com/party*",
        "*://*.pokefarm.com/user*",
        "*://*.pokefarm.com/trade*",
        "*://*.pokefarm.com/shelter*"
      ],
      "js": [
        "bundle.js"
      ],
      "css": [],
      "run_at": "document_idle",
      "type": "module"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "network-interceptor.js"
      ],
      "matches": [
        "*://*.pokefarm.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pfq-iv-checker@luansing.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}